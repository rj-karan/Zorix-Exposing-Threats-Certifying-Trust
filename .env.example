# ============================================================
# Zorix Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
# Use "sqlite" for local development, "postgres" for production
DATABASE_TYPE=sqlite
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=zorix
POSTGRES_USER=zorix_user
POSTGRES_PASSWORD=zorix_password

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- GitHub ---
# Personal access token for accessing private repositories
GITHUB_TOKEN=

# --- AI / LLM Configuration ---
# Provider: ollama (free, local) | anthropic | openai
AI_PROVIDER=ollama
AI_MODEL=mistral

# Ollama (default — free, locally hosted)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=180

# Anthropic (optional — requires paid API key)
ANTHROPIC_API_KEY=

# OpenAI (optional — requires paid API key)
OPENAI_API_KEY=

# --- External APIs ---
# NVD API key (optional, increases rate limits)
NVD_API_KEY=
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0

# --- Docker Sandbox ---
DOCKER_SOCKET=unix:///var/run/docker.sock
SANDBOX_IMAGE=zorix-sandbox:latest
SANDBOX_TIMEOUT=60
SANDBOX_MEMORY=512m
SANDBOX_CPUS=0.5

# --- Storage Paths ---
SNAPSHOT_DIR=./tmp/snapshots
EXPLOIT_DIR=./tmp/exploits
REPORTS_DIR=./reports
LOGS_DIR=./logs

# --- Scanner Configuration ---
BANDIT_ENABLED=true
SEMGREP_ENABLED=true
NUCLEI_ENABLED=false
BANDIT_PATH=bandit
SEMGREP_PATH=semgrep
NUCLEI_PATH=nuclei

# --- Application ---
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Notifications ---
DEFAULT_WEBHOOK_URL=
EMAIL_NOTIFICATIONS=false
NOTIFICATION_EMAIL=
